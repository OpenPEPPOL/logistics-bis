<?xml version="1.0" encoding="UTF-8"?>
<testSet xmlns="http://difi.no/xsd/vefa/validator/1.0" configuration="peppolbis-t018-base-1.2">
	<assert>
		<description>Verify that the cbc:CustomizationID is correct</description>
		<scope>PEPPOL-T018-R013</scope>
	</assert>
	
	<test id="1">
		<assert>
			<success>PEPPOL-T018-R013</success>
		</assert>
		<ApplicationResponse xmlns="urn:oasis:names:specification:ubl:schema:xsd:ApplicationResponse-2"
							 xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
							 xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
			<cbc:UBLVersionID>2.2</cbc:UBLVersionID>
			<cbc:CustomizationID>urn:fdc:peppol.eu:prac:trns:t018:1</cbc:CustomizationID>
			<cbc:ProfileID>urn:fdc:peppol.eu:prac:bis:p010</cbc:ProfileID>
		</ApplicationResponse>
	</test>

	<test>
		<assert id="2">
			<error>PEPPOL-T018-R013</error>
		</assert>
		<ApplicationResponse xmlns="urn:oasis:names:specification:ubl:schema:xsd:ApplicationResponse-2"
							 xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
							 xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
			<cbc:UBLVersionID>2.2</cbc:UBLVersionID>
			<cbc:CustomizationID>urn:fdc:peppol.eu:prac:trnsx:t018:1</cbc:CustomizationID>
			<cbc:ProfileID>urn:fdc:peppol.eu:prac:bis:p010</cbc:ProfileID>
		</ApplicationResponse>
	</test>

</testSet>
