<?xml version="1.0" encoding="UTF-8"?>
<testSet xmlns="http://difi.no/xsd/vefa/validator/1.0" configuration="peppolbis-t012-base-1.3">
	<assert>
		<description>Verify that requestId is a valid UUID</description>
		<scope>PEPPOL-T012-R002</scope>
	</assert>

	<test id="1">
		<assert>
			<success>PEPPOL-T012-R002</success>
		</assert>
		<query:QueryResponse xmlns:query="urn:oasis:names:tc:ebxml-regrep:xsd:query:4.0"
							 requestId="48ac7379-731d-40be-bc48-599934182d45"/>
	</test>

	<test>
		<assert id="2">
			<error>PEPPOL-T012-R002</error>
		</assert>
		<query:QueryResponse xmlns:query="urn:oasis:names:tc:ebxml-regrep:xsd:query:4.0"
							 requestId="not-a-uuid"/>
	</test>

</testSet>
