<?xml version="1.0" encoding="UTF-8"?>
<testSet xmlns="http://difi.no/xsd/vefa/validator/1.0" configuration="peppolbis-t006-base-1.2">
	<assert>
		<description>Verify that the cbc:CustomizationID is correct</description>
		<scope>PEPPOL-T006-R002</scope>
	</assert>
	
	<test id="1">
		<assert>
			<success>PEPPOL-T006-R002</success>
		</assert>
		<TenderReceipt xmlns="urn:oasis:names:specification:ubl:schema:xsd:TenderReceipt-2"
			xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
			xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
			<cbc:UBLVersionID>2.2</cbc:UBLVersionID>
			<cbc:CustomizationID>urn:fdc:peppol.eu:prac:trns:t006:1</cbc:CustomizationID>
			<cbc:ProfileID>urn:fdc:peppol.eu:prac:bis:p003</cbc:ProfileID>
		</TenderReceipt>
	</test>

	<test>
		<assert id="2">
			<error>PEPPOL-T006-R002</error>
		</assert>
		<TenderReceipt xmlns="urn:oasis:names:specification:ubl:schema:xsd:TenderReceipt-2"
			xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
			xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
			<cbc:UBLVersionID>2.2</cbc:UBLVersionID>
			<cbc:CustomizationID>urn:fdc:peppol.eu:prac:trnsx:t006:1</cbc:CustomizationID>
			<cbc:ProfileID>urn:fdc:peppol.eu:prac:bis:p003</cbc:ProfileID>
		</TenderReceipt>
	</test>

</testSet>
