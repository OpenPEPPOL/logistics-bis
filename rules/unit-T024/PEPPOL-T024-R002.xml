<?xml version="1.0" encoding="UTF-8"?>
<testSet xmlns="http://difi.no/xsd/vefa/validator/1.0" configuration="peppolbis-t024-base-1.0">
	<assert>
		<description>Verify that the cbc:CustomizationID is correct</description>
		<scope>PEPPOL-T024-R002</scope>
	</assert>
	
	<test id="1">
		<assert>
			<success>PEPPOL-T024-R002</success>
		</assert>
		<CallForTenders
